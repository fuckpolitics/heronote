# ── База данных: PostgreSQL ──
# Строку подключения возьми в Neon (Connection string, формат postgresql://...).
# Локально можно использовать ту же строку, что и в проде.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Секрет для подписи JWT — обязательно длинная случайная строка
JWT_SECRET="change-me-to-a-long-random-string"

# Порт API (локально 3000; на Render выставляется автоматически)
PORT=3000

# Разрешённые источники (CORS). "*" подходит, т.к. токен в заголовке, не в cookie.
CORS_ORIGIN="*"
